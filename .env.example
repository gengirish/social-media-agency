# === CampaignForge AI — Environment Variables ===

# App
APP_ENV=dev
DEBUG=true

# OAuth token encryption (Fernet). Required when APP_ENV is not dev.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In dev, if omitted, a built-in development key is used (not for production).
TOKEN_ENCRYPTION_KEY=

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/campaignforge
NEON_DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_EXPIRE_MINUTES=60

# Clerk (set on Vercel). If unset, backend accepts JWT from POST /auth/login (pairs with seeded users in db/seed.sql).
CLERK_SECRET_KEY=
CLERK_JWKS_URL=

# Optional: first Clerk sign-in for these emails uses the demo org from db/seed.sql (see DEMO_ORG_ID there).
# DEMO_ORG_ID=a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11
# DEMO_ORG_ALLOWLIST=you@company.com

# LLM Providers (at least one required)
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AgentMail
AGENTMAIL_API_KEY=
AGENTMAIL_DEFAULT_DOMAIN=

# Storage (S3/R2 for media)
S3_BUCKET_NAME=campaignforge-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001
