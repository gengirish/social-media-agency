# === CampaignForge AI — Environment Variables ===

# App
APP_ENV=dev
DEBUG=true

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/campaignforge
NEON_DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_EXPIRE_MINUTES=60

# LLM Providers (at least one required)
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Stripe (billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AgentMail
AGENTMAIL_API_KEY=
AGENTMAIL_DEFAULT_DOMAIN=

# Storage (S3/R2 for media)
S3_BUCKET_NAME=campaignforge-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8001
